{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Frostlog",
  "version": "0.3.0",
  "identifier": "com.frostlog.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Frostlog",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": true,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFRUMzRUY0NDdFOERGNkMKUldSczMraEg5RDdzYmhiUGEyYnRtcjFNRmJQVTBsYW1KS21RS256UXE5dHhGY3J5VmJpbUQ5VXYK",
      "endpoints": [
        "https://github.com/martensq/frostlog/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/logo.ico"
    ]
  }
}
