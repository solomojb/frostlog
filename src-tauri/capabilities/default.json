{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:webview:allow-set-webview-zoom",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive"
  ]
}
